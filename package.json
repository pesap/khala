{
  "name": "khala",
  "version": "0.1.0",
  "description": "Single self-learning developer agent package for Pi",
  "type": "module",
  "keywords": [
    "pi-package",
    "pi-extension",
    "pi-skill",
    "gitagent"
  ],
  "license": "MIT",
  "exports": {
    ".": "./khala/index.ts",
    "./harness": "./khala/harness.ts"
  },
  "scripts": {
    "smoke": "npm run lint && npm run test",
    "test": "npm run typecheck && npm run test:node",
    "test:node": "node --test --experimental-strip-types tests/**/*.test.ts",
    "test:pi": "bash scripts/test-pi-khala-memory.sh",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write ."
  },
  "pi": {
    "extensions": [
      "./khala/index.ts"
    ],
    "skills": [
      "./skills",
      "./node_modules/pi-subagents/skills"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "dependencies": {
    "@ff-labs/pi-fff": "^0.9.1",
    "js-yaml": "^4.1.1",
    "pi-subagents": "^0.24.2"
  },
  "bundledDependencies": [
    "@ff-labs/pi-fff",
    "pi-subagents"
  ],
  "devDependencies": {
    "@biomejs/biome": "^2.2.6",
    "@types/js-yaml": "^4.0.9",
    "prettier": "3.8.3",
    "typescript": "^6.0.3"
  },
  "bundleDependencies": [
    "@ff-labs/pi-fff",
    "pi-subagents"
  ]
}
