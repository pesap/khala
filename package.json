{
  "name": "khala",
  "version": "0.1.0",
  "description": "Single self-learning developer agent package for Pi",
  "type": "module",
  "keywords": [
    "pi-package",
    "pi-extension",
    "pi-skill",
    "gitagent"
  ],
  "license": "MIT",
  "exports": {
    ".": "./extensions/index.ts",
    "./harness": "./khala/harness.ts"
  },
  "bin": {
    "khala": "./bin/khala.js"
  },
  "scripts": {
    "smoke": "npm run lint && npm run test",
    "test": "npm run typecheck && npm run test:node",
    "test:node": "node --test --experimental-strip-types tests/**/*.test.ts",
    "test:pi": "bash scripts/test-pi-khala-memory.sh",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "lint:md": "markdownlint-cli2 'skills/**/*.md' '#**/node_modules/**'",
    "lint:yaml": "yamllint .",
    "lint:sh": "shellcheck scripts/*.sh",
    "lint:spell": "cspell 'skills/**/*.md' 'runtime/**/*.yaml' 'workflows/**/*.yaml'",
    "lint:all": "npm run lint && npm run lint:md && npm run lint:yaml && npm run lint:sh && npm run lint:spell",
    "format": "biome format --write .",
    "format:md": "prettier --write 'skills/**/*.md' 'skills/**/*.yaml' 'skills/**/*.yml' 'runtime/**/*.yaml' 'workflows/**/*.yaml' '.github/**/*.yml'"
  },
  "pi": {
    "extensions": [
      "./extensions/index.ts"
    ],
    "prompts": [
      "./prompts"
    ],
    "skills": [
      "./skills",
      "./node_modules/pi-subagents/skills"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "dependencies": {
    "@ff-labs/pi-fff": "^0.9.1",
    "js-yaml": "^4.1.1",
    "pi-subagents": "^0.24.2"
  },
  "bundledDependencies": [
    "@ff-labs/pi-fff",
    "pi-subagents"
  ],
  "devDependencies": {
    "@biomejs/biome": "^2.2.6",
    "@types/js-yaml": "^4.0.9",
    "cspell": "^10.0.1",
    "markdownlint-cli2": "^0.22.1",
    "prettier": "3.8.3",
    "shellcheck": "^4.1.0",
    "typescript": "^6.0.3"
  },
  "bundleDependencies": [
    "@ff-labs/pi-fff",
    "pi-subagents"
  ]
}
