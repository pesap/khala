{
  "name": "khala",
  "version": "0.1.0",
  "description": "Single self-learning developer agent package for Pi",
  "type": "module",
  "keywords": [
    "pi-package",
    "pi-extension",
    "pi-skill",
    "gitagent"
  ],
  "license": "MIT",
  "files": [
    "bin",
    "commands",
    "docs",
    "extensions",
    "intercepted-commands",
    "khala",
    "prompts",
    "runtime",
    "scripts",
    "skills",
    "types",
    "workflows"
  ],
  "exports": {
    ".": "./extensions/index.ts",
    "./harness": "./khala/harness.ts"
  },
  "bin": {
    "khala": "./bin/khala.js"
  },
  "scripts": {
    "smoke": "npm run lint:all && npm run test",
    "test": "npm run typecheck && npm run test:node",
    "test:node": "node --test --experimental-strip-types tests/**/*.test.ts",
    "test:pi": "bash scripts/test-pi-khala-memory.sh",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "lint:md": "markdownlint-cli2 README.md docs/maintainer-os-north-star.md",
    "lint:yaml": "git ls-files '*.yml' '*.yaml' | xargs yamllint",
    "lint:sh": "shellcheck scripts/*.sh",
    "lint:spell": "cspell --no-progress README.md docs/maintainer-os-north-star.md .github/workflows/ci.yml",
    "lint:all": "npm run lint && npm run lint:md && npm run lint:yaml && npm run lint:sh && npm run lint:spell",
    "format": "biome format --write .",
    "format:md": "prettier --write 'skills/**/*.md' 'skills/**/*.yaml' 'skills/**/*.yml' 'runtime/**/*.yaml' 'workflows/**/*.yaml' '.github/**/*.yml'"
  },
  "pi": {
    "extensions": [
      "./extensions/index.ts"
    ],
    "prompts": [
      "./prompts"
    ],
    "skills": [
      "./skills",
      "./node_modules/pi-subagents/skills"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-ai": {
      "optional": true
    },
    "@earendil-works/pi-coding-agent": {
      "optional": true
    },
    "@earendil-works/pi-tui": {
      "optional": true
    },
    "typebox": {
      "optional": true
    }
  },
  "dependencies": {
    "@ff-labs/pi-fff": "^0.9.6",
    "js-yaml": "^5.1.0",
    "pi-subagents": "^0.30.0"
  },
  "bundledDependencies": [
    "@ff-labs/pi-fff",
    "pi-subagents"
  ],
  "devDependencies": {
    "@biomejs/biome": "^2.2.6",
    "@earendil-works/pi-ai": "0.79.10",
    "@earendil-works/pi-coding-agent": "0.79.10",
    "@earendil-works/pi-tui": "0.79.10",
    "@types/js-yaml": "^4.0.9",
    "cspell": "^10.0.1",
    "markdownlint-cli2": "^0.22.1",
    "prettier": "3.8.3",
    "shellcheck": "^4.1.0",
    "typescript": "^6.0.3",
    "typebox": "1.1.38",
    "yaml-lint": "^1.7.0"
  },
  "bundleDependencies": [
    "@ff-labs/pi-fff",
    "pi-subagents"
  ]
}
