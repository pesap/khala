{
  "version": 1,
  "name": "Khala Harness Golden Corpus",
  "description": "Small deterministic regression cases for transcript replay, harness policy checks, temporal package contracts, and CI thresholds.",
  "cases": [
    {
      "id": "golden-memory-focused-pass",
      "name": "Memory gate accepts focused search before mutation",
      "tags": ["golden", "memory-gate", "mutation"],
      "userText": "Update README.md remediation loop notes.",
      "harnessLimits": { "substantialToolCallThreshold": 99 },
      "runs": [
        {
          "id": "focused-memory-retry",
          "model": "golden/example",
          "assistantText": "I updated README.md after the focused memory refresh.",
          "messages": [
            {
              "role": "user",
              "text": "Update README.md remediation loop notes."
            },
            {
              "role": "assistant",
              "toolCall": {
                "name": "khala_search_memory",
                "arguments": {
                  "query": "README.md remediation loop documentation memory gate"
                }
              }
            },
            {
              "role": "toolResult",
              "text": "Memory search found README remediation guidance."
            },
            {
              "role": "assistant",
              "toolCall": {
                "name": "read",
                "arguments": { "path": "skills/docs-authoring/SKILL.md" }
              }
            },
            { "role": "toolResult", "text": "Docs authoring guidance loaded." },
            {
              "role": "assistant",
              "toolCall": {
                "name": "read",
                "arguments": { "path": "README.md" }
              }
            },
            { "role": "toolResult", "text": "README contents" },
            {
              "role": "assistant",
              "toolCall": {
                "name": "apply_patch",
                "arguments": { "path": "README.md" }
              }
            },
            { "role": "toolResult", "text": "patched README.md" }
          ],
          "expectedIssueCodes": []
        }
      ]
    },
    {
      "id": "golden-memory-blocked-replay",
      "name": "Fake replay captures blocked mutation recovery",
      "tags": ["golden", "memory-gate", "fake-runtime-replay"],
      "userText": "Patch README.md after memory is fresh.",
      "harnessLimits": { "substantialToolCallThreshold": 99 },
      "runs": [
        {
          "id": "scripted-memory-recovery",
          "model": "golden/fake-runner",
          "assistantText": "The blocked mutation was retried after khala_read_memory.",
          "transcript": {
            "version": 1,
            "metadata": {
              "source": "khala-runner",
              "scenario": "memory-recovery"
            },
            "events": [
              {
                "type": "user_input",
                "text": "Patch README.md after memory is fresh.",
                "source": "script"
              },
              {
                "type": "tool_call_requested",
                "callId": "call-apply-1",
                "name": "apply_patch",
                "arguments": { "path": "README.md" }
              },
              {
                "type": "memory_gate",
                "decision": "blocked",
                "toolName": "apply_patch",
                "message": "MEMORY READ REQUIRED"
              },
              {
                "type": "tool_call_blocked",
                "callId": "call-apply-1",
                "name": "apply_patch",
                "code": "memory_read_required",
                "message": "MEMORY READ REQUIRED"
              },
              {
                "type": "tool_call_requested",
                "callId": "call-memory-1",
                "name": "khala_read_memory",
                "arguments": { "scope": "task" }
              },
              {
                "type": "tool_result",
                "callId": "call-memory-1",
                "name": "khala_read_memory",
                "ok": true,
                "text": "memory fresh"
              },
              {
                "type": "tool_call_requested",
                "callId": "call-apply-2",
                "name": "apply_patch",
                "arguments": { "path": "README.md" }
              },
              {
                "type": "tool_call_allowed",
                "callId": "call-apply-2",
                "name": "apply_patch",
                "message": "memory fresh"
              },
              {
                "type": "tool_result",
                "callId": "call-apply-2",
                "name": "apply_patch",
                "ok": true,
                "text": "patched README.md"
              },
              {
                "type": "assistant_final",
                "text": "The blocked mutation was retried after khala_read_memory."
              }
            ]
          },
          "expectedIssueCodes": [
            "memory_search",
            "evidence_routing",
            "implementation_quality"
          ]
        }
      ]
    },
