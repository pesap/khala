    {
      "id": "golden-workon-temporal-assertions",
      "name": "Workon temporal package assertions catch order regressions",
      "tags": ["golden", "workon", "temporal-package"],
      "userText": "Session capsule path: /tmp/capsule.md",
      "harnessLimits": { "substantialToolCallThreshold": 99 },
      "packageContract": {
        "name": "workon temporal ordering",
        "orderedToolCalls": [
          { "name": "read", "argumentIncludes": ["capsule.md"] },
          {
            "name": "exec_command",
            "argumentIncludes": [
              "workon-handoff-ack.sh",
              "capsule-acknowledged"
            ]
          },
          {
            "name": "exec_command",
            "argumentIncludes": ["git commit", "--allow-empty"]
          },
          {
            "name": "exec_command",
            "argumentIncludes": ["gh pr create", "--draft"]
          }
        ],
        "forbiddenBefore": [
          {
            "forbidden": { "name": "apply_patch" },
            "before": {
              "name": "exec_command",
              "argumentIncludes": ["gh pr create", "--draft"]
            }
          },
          {
            "forbidden": { "name": "edit" },
            "before": {
              "name": "exec_command",
              "argumentIncludes": ["gh pr create", "--draft"]
            }
          }
        ],
        "requiredBefore": [
          {
            "required": { "name": "read", "argumentIncludes": ["capsule.md"] },
            "before": {
              "name": "exec_command",
              "argumentIncludes": [
                "workon-handoff-ack.sh",
                "capsule-acknowledged"
              ]
            }
          },
          {
            "required": {
              "name": "exec_command",
              "argumentIncludes": ["git commit", "--allow-empty"]
            },
            "before": {
              "name": "exec_command",
              "argumentIncludes": ["gh pr create", "--draft"]
            }
          }
        ],
        "nextToolMustBe": [
          {
            "after": { "name": "read", "argumentIncludes": ["capsule.md"] },
            "next": {
              "name": "exec_command",
              "argumentIncludes": [
                "workon-handoff-ack.sh",
                "capsule-acknowledged"
              ]
            }
          }
        ]
      },
      "runs": [
        {
          "id": "workon-order-happy",
          "model": "golden/example",
          "assistantText": "I read the capsule, acknowledged it, created the empty commit, and opened the draft PR.",
          "messages": [
            { "role": "user", "text": "Session capsule path: /tmp/capsule.md" },
            {
              "role": "assistant",
              "toolCall": {
                "name": "read",
                "arguments": { "path": "/tmp/capsule.md" }
              }
            },
            { "role": "toolResult", "text": "capsule" },
            {
              "role": "assistant",
              "toolCall": {
                "name": "exec_command",
                "arguments": {
                  "cmd": "bash scripts/workon-handoff-ack.sh --status capsule-acknowledged"
                }
              }
            },
            { "role": "toolResult", "text": "capsule-acknowledged" },
            {
              "role": "assistant",
              "toolCall": {
                "name": "exec_command",
                "arguments": { "cmd": "git commit --allow-empty -m bootstrap" }
              }
            },
            { "role": "toolResult", "text": "empty bootstrap commit" },
            {
              "role": "assistant",
              "toolCall": {
                "name": "exec_command",
                "arguments": { "cmd": "gh pr create --draft --title bootstrap" }
              }
            },
            { "role": "toolResult", "text": "draft PR" }
          ],
          "expectedIssueCodes": ["memory_search"]
        },
        {
          "id": "ack-before-capsule-read",
          "model": "golden/example",
          "assistantText": "I acknowledged before reading.",
          "messages": [
            { "role": "user", "text": "Session capsule path: /tmp/capsule.md" },
            {
              "role": "assistant",
              "toolCall": {
                "name": "exec_command",
                "arguments": {
                  "cmd": "bash scripts/workon-handoff-ack.sh --status capsule-acknowledged"
                }
              }
            },
            { "role": "toolResult", "text": "capsule-acknowledged" },
            {
              "role": "assistant",
              "toolCall": {
                "name": "read",
                "arguments": { "path": "/tmp/capsule.md" }
              }
            },
            { "role": "toolResult", "text": "capsule" },
            {
              "role": "assistant",
              "toolCall": {
                "name": "exec_command",
                "arguments": { "cmd": "git commit --allow-empty -m bootstrap" }
              }
            },
            { "role": "toolResult", "text": "empty bootstrap commit" },
            {
              "role": "assistant",
              "toolCall": {
                "name": "exec_command",
                "arguments": { "cmd": "gh pr create --draft --title bootstrap" }
              }
            },
            { "role": "toolResult", "text": "draft PR" }
          ],
          "expectedIssueCodes": ["memory_search"],
          "expectedPackageIssueCodes": [
            "package_run_tool_order_violation",
            "package_run_required_tool_missing_before_anchor",
            "package_run_next_tool_mismatch"
          ]
        },
        {
          "id": "edit-before-draft-pr",
          "model": "golden/example",
          "assistantText": "I edited before opening the draft PR.",
          "messages": [
            { "role": "user", "text": "Session capsule path: /tmp/capsule.md" },
            {
              "role": "assistant",
              "toolCall": {
                "name": "read",
                "arguments": { "path": "/tmp/capsule.md" }
              }
            },
            { "role": "toolResult", "text": "capsule" },
            {
              "role": "assistant",
              "toolCall": {
                "name": "exec_command",
                "arguments": {
                  "cmd": "bash scripts/workon-handoff-ack.sh --status capsule-acknowledged"
                }
              }
            },
            { "role": "toolResult", "text": "capsule-acknowledged" },
            {
              "role": "assistant",
              "toolCall": {
                "name": "exec_command",
                "arguments": { "cmd": "git commit --allow-empty -m bootstrap" }
              }
            },
            { "role": "toolResult", "text": "empty bootstrap commit" },
            {
              "role": "assistant",
              "toolCall": {
                "name": "apply_patch",
                "arguments": { "path": "src/index.ts" }
              }
            },
            { "role": "toolResult", "text": "patched" },
            {
              "role": "assistant",
              "toolCall": {
                "name": "exec_command",
                "arguments": { "cmd": "gh pr create --draft --title bootstrap" }
              }
            },
            { "role": "toolResult", "text": "draft PR" }
          ],
          "expectedIssueCodes": ["memory_search", "implementation_quality"],
          "expectedPackageIssueCodes": [
            "package_run_forbidden_tool_before_anchor"
          ]
        },
        {
          "id": "draft-pr-before-empty-commit",
          "model": "golden/example",
          "assistantText": "I opened the draft PR before the empty commit.",
          "messages": [
            { "role": "user", "text": "Session capsule path: /tmp/capsule.md" },
            {
              "role": "assistant",
              "toolCall": {
                "name": "read",
                "arguments": { "path": "/tmp/capsule.md" }
              }
            },
            { "role": "toolResult", "text": "capsule" },
            {
              "role": "assistant",
              "toolCall": {
                "name": "exec_command",
                "arguments": {
                  "cmd": "bash scripts/workon-handoff-ack.sh --status capsule-acknowledged"
                }
              }
            },
            { "role": "toolResult", "text": "capsule-acknowledged" },
            {
              "role": "assistant",
              "toolCall": {
                "name": "exec_command",
                "arguments": { "cmd": "gh pr create --draft --title bootstrap" }
              }
            },
            { "role": "toolResult", "text": "draft PR" },
            {
              "role": "assistant",
              "toolCall": {
                "name": "exec_command",
                "arguments": { "cmd": "git commit --allow-empty -m bootstrap" }
              }
            },
            { "role": "toolResult", "text": "empty bootstrap commit" }
          ],
          "expectedIssueCodes": ["memory_search"],
          "expectedPackageIssueCodes": [
            "package_run_tool_order_violation",
            "package_run_required_tool_missing_before_anchor"
          ]
        }
      ]
    }
  ]
}
